# ── Server configuration ──────────────────────────────────────────────────
# VITE_API_BASE_URL: URL base API yang digunakan oleh Frontend (React).
# Kosong ("")            = FE hit server yang sama dengan host (default)
# http://localhost:8000  = FE langsung hit Python FastAPI (Ollama mode)
VITE_API_BASE_URL="http://localhost:8000"

# ── Konfigurasi Multi-LLM Provider ────────────────────────────────────────
# LLM_PROVIDER: Pilih provider AI yang ingin digunakan.
# Opsi: ollama (default), openai, openrouter, groq, gemini
LLM_PROVIDER="ollama"

# ── Konfigurasi Provider Cloud (GPT/Claude/Gemini/dll) ───────────────────
# Diperlukan jika LLM_PROVIDER bukan 'ollama'
# AI_BASE_URL: URL API (default: https://api.openai.com/v1)
AI_BASE_URL="https://api.openai.com/v1"

# AI_API_KEY: API Key (untuk OpenAI, OpenRouter, Groq, dll)
AI_API_KEY="your_api_key_here"

# GEMINI_API_KEY: API Key khusus jika pakai provider 'gemini'
GEMINI_API_KEY="your_gemini_key_here"

# AI_MODEL: Model spesifik (misal: gpt-4o, claude-3-sonnet, gemini-1.5-flash)
AI_MODEL="llama-3-70b"

# ── Konfigurasi Ollama (Lokal) ───────────────────────────────────────────
# OLLAMA_BASE_URL: Base URL tempat server Ollama berjalan.
OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL: Nama model Ollama yang akan digunakan.
OLLAMA_MODEL="llama3"
# OLLAMA_TIMEOUT: Batas waktu tunggu response (dalam detik).
OLLAMA_TIMEOUT="180"

# ── Konfigurasi Semantic Cache ─────────────────────────────────────────────
# SEMANTIC_CACHE_ENABLED: Aktifkan cache semantik (true/false)
SEMANTIC_CACHE_ENABLED="true"
# SEMANTIC_CACHE_THRESHOLD: Batas tingkat kemiripan (0.90 - 0.98)
SEMANTIC_CACHE_THRESHOLD="0.95"
