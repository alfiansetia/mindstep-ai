# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: URL base API yang digunakan oleh Frontend (React).
# Kosong ("")            = FE hit server yang sama dengan host (default)
# http://localhost:8000  = FE langsung hit Python FastAPI (Ollama mode)
VITE_API_BASE_URL="http://localhost:8000"

# ── Konfigurasi Ollama ─────────────────────────────────────────────────────
# OLLAMA_BASE_URL: Base URL tempat server Ollama berjalan.
# Lokal (default) : http://localhost:11434
# Remote / luar   : http://192.168.1.100:11434  atau  http://my-server.com:11434
OLLAMA_BASE_URL="http://localhost:11434"

# OLLAMA_MODEL: Nama model Ollama yang akan digunakan.
# Contoh: llama3, mistral, gemma2, phi3, dll.
OLLAMA_MODEL="llama3"

# OLLAMA_TIMEOUT: Batas waktu tunggu response dari Ollama (dalam detik).
# LLM lokal bisa lambat, terutama saat pertama kali load model.
# Naikkan jika sering kena error 503 (default: 180)
OLLAMA_TIMEOUT="180"

# ── Konfigurasi Semantic Cache ─────────────────────────────────────────────
# SEMANTIC_CACHE_ENABLED: Aktifkan cache semantik untuk mempercepat respon AI yang serupa (true/false)
SEMANTIC_CACHE_ENABLED="true"

# SEMANTIC_CACHE_THRESHOLD: Batas tingkat kemiripan semantik (0.0 - 1.0)
# Nilai lebih tinggi (misal: 0.90) = pencocokan harus sangat mirip.
# Nilai lebih rendah (misal: 0.80) = pencocokan lebih fleksibel.
SEMANTIC_CACHE_THRESHOLD="0.88"
