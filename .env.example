# ── Konfigurasi Aplikasi ──────────────────────────────────────────────────
# VITE_API_BASE_URL: Kosongkan jika dideploy satu paket dengan server.py
# Isi "http://localhost:8000" jika development (npm run dev & uvicorn run terpisah)
VITE_API_BASE_URL="http://localhost:8000"

# ── Konfigurasi Multi-LLM Provider ────────────────────────────────────────
# Opsi: ollama, openai, openrouter, groq, gemini
LLM_PROVIDER="gemini"

# ── Konfigurasi Provider Cloud ────────────────────────────────────────────
# Diperlukan jika LLM_PROVIDER bukan 'ollama'
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY="your-api-key-here"
# Khusus jika pakai provider 'gemini'
GEMINI_API_KEY="your-gemini-api-key-here"
# Model spesifik (misal: gpt-4o, gemini-1.5-flash, qwen2.5:3b)
AI_MODEL="gemini-1.5-flash"

# ── Konfigurasi Ollama (Lokal) ────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:3b"
OLLAMA_TIMEOUT="180"

# ── Konfigurasi Semantic Cache ────────────────────────────────────────────
# SEMANTIC_CACHE_ENABLED: true/false (Membutuhkan Ollama untuk embedding)
SEMANTIC_CACHE_ENABLED="false"
SEMANTIC_CACHE_THRESHOLD="0.95"

# ── Konfigurasi Akses Host (Tunnel/Custom Domain) ─────────────────────────
# Masukkan domain tunnel lo di sini agar Vite mengizinkan akses. Pisahkan dengan koma jika banyak.
VITE_ALLOWED_HOSTS="yourdomain.com,localhost"
